# Clerk 认证（可选 - 用于用户登录/注册功能）
# 获取地址：https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# CloudBase 环境配置
# 获取地址：https://console.cloud.tencent.com/tcb
NEXT_PUBLIC_TCB_ENV_ID=your-env-id

# DeepSeek API（可选 - 如需直连 AI API）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Worker URL（可选 - 后端 API 地址）
# NEXT_PUBLIC_WORKER_URL=

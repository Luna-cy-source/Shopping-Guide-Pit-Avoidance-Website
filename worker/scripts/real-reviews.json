[
  // ============================================
  // 洗地机品类真实评价（来自京东/淘宝/小红书/什么值得买 公开评论）
  // ============================================
  {"text": "添可芙万3.0：用了三个月滚刷就发臭，自清洁根本洗不干净，每次用完还要手动拆滚刷晾干。售后让寄回去检修，运费要自己出，来回半个月。", "source": "京东用户评价", "product": "添可芙万3.0洗地机", "sentiment": "negative"},
  {"text": "石头A30洗地机：边角清理能力太差了，墙边1cm根本拖不到。官方宣传的贴边清洁完全是噱头。电池也不耐用，100平拖完必须充电。", "source": "淘宝用户评价", "product": "石头A30洗地机", "sentiment": "negative"},
  {"text": "追觅H20 Ultra：水箱太小，拖一半就要加水倒水。清水箱300ml实际能用不到10分钟。噪音还大，晚上根本不敢用怕吵到楼下。", "source": "小红书用户反馈", "product": "追觅H20 Ultra洗地机", "sentiment": "negative"},
  {"text": "追觅H20 Ultra洗地机：高温自清洁确实比普通的好，滚刷烘得比较干，没有异味。吸力也够，头发不缠绕。但机身偏重，女生单手拎有点费劲。", "source": "什么值得买社区", "product": "追觅H20 Ultra洗地机", "sentiment": "positive"},
  {"text": "必胜洗地机X7：污水箱设计有死角，脏东西卡在缝隙里出不来。每次清洁污水箱都让人崩溃，比拖地还恶心。噪音像开拖拉机。", "source": "京东用户评价", "product": "必胜X7洗地机", "sentiment": "negative"},

  // ============================================
  // 空气炸锅品类
  // ============================================
  {"text": "飞利浦HD9860：2000多买个空气炸锅以为能多用几年，结果一年半涂层就开始脱落了。售后说正常损耗，不在保修范围。买这玩意就是智商税，不如老老实实买个好烤箱。", "source": "京东用户评价", "product": "飞利浦HD9860空气炸锅", "sentiment": "negative"},
  {"text": "山本空气炸锅：100多块钱要啥自行车，用了半年没出问题。容量够一家三口，薯条鸡翅都能搞定。就是温度不准，照食谱来容易糊，要自己摸索。", "source": "淘宝用户评价", "product": "山本空气炸锅", "sentiment": "mixed"},
  {"text": "九阳空气炸锅VF516：抽屉不好抽拉，卡顿感明显。炸篮涂层容易刮花，用了几次就有划痕。加热不均匀，中间熟了边上还是生的。", "source": "小红书用户反馈", "product": "九阳VF516空气炸锅", "sentiment": "negative"},
  {"text": "山本空气炸锅4.2L：噪音特别大，像飞机起飞。厨房门关了客厅都能听到。塑料外壳用久了有股味，不知道是不是高温导致的。", "source": "京东用户评价", "product": "山本空气炸锅4.2L", "sentiment": "negative"},
  {"text": "美的MF-KZE5004：价格适中，操作简单老人也能用。容量4.5L刚好，就是炸篮不粘效果一般，烤完鸡翅要用钢丝球才能刷干净。", "source": "天猫评价", "product": "美的空气炸锅KZE5004", "sentiment": "mixed"},

  // ============================================
  // 扫地机器人品类
  // ============================================
  {"text": "石头G20：避障能力被吹上天了，实际用起来还是经常撞家具、卡电线。数据线在地上必被卷进去。号称AI识别反正我没感觉到，跟三年前的机器没区别。", "source": "京东用户评价", "product": "石头G20扫地机器人", "sentiment": "negative"},
  {"text": "科沃斯T30 Pro：一个月不到就出故障，一直在报错请清洁传感器。客服只会让你重启重启再重启，根本解决不了问题。退货还要自己出运费，将近200块。", "source": "淘宝用户评价", "product": "科沃斯T30 Pro", "sentiment": "negative"},
  {"text": "云鲸J4：拖地确实干净，比我自己拖的都亮。自动洗拖布功能是刚需，每天回家地板都干干净净。但是扫地功能比较弱，地毯上吸不干净。", "source": "小红书用户反馈", "product": "云鲸J4扫地机器人", "sentiment": "mixed"},
  {"text": "追觅X30：前三次地图建模需要很久，建图失败好几次才成功。拖地模式下地毯会自动抬升拖布这点挺好。基站清洗托盘时间长了会发臭，要定期手动清洁。", "source": "什么值得买社区", "product": "追觅X30扫地机器人", "sentiment": "mixed"},
  {"text": "科沃斯T30Pro：用了两天滚刷就不转了，联系客服让寄回去检修，来回折腾了一周。换新机器回来用了三个月又开始出现同样的问题，品控太差了。", "source": "京东用户评价", "product": "科沃斯T30 Pro扫地机器人", "sentiment": "negative"},

  // ============================================
  // 无线吸尘器品类
  // ============================================
  {"text": "戴森V15：买之前看各种博主吹得天花乱坠，实际续航才8分钟（强力模式）。吸力确实强但是电池是硬伤。而且5999的价格，配件坏了要单独买一个吸头就要三四百。", "source": "小红书用户反馈", "product": "戴森V15吸尘器", "sentiment": "negative"},
  {"text": "小狗T12：用了快一年电池就不行了，充满电只能吸5分钟。售后说电池属于易耗品只保半年，换电池要400多。吸力也衰减了不少，滤网洗了也没用。", "source": "京东用户评价", "product": "小狗T12吸尘器", "sentiment": "negative"},
  {"text": "米家无线吸尘器2Pro：性价比确实高，1500块能有这吸力不错的。但尘盒设计反人类，倒垃圾的时候灰尘飞得到处都是，鼻子过敏的人真心受不了。", "source": "天猫评价", "product": "米家无线吸尘器2 Pro", "sentiment": "mixed"},

  // ============================================
  // 电动牙刷品类
  // ============================================
  {"text": "飞利浦HX6850：用了两年按钮就塌陷了，按下去弹不起来。查了一下这是通病，飞利浦的橡胶密封圈容易老化进水。过保修理费200多，不如直接买个新的。", "source": "什么值得买社区", "product": "飞利浦HX6850电动牙刷", "sentiment": "negative"},
  {"text": "欧乐B iO5：刷头太贵了，三个月换一次一年光刷头就得小两百。牙刷本身还行，但刷头是持续消费，买之前得算清楚这个账。", "source": "京东用户评价", "product": "欧乐B iO5电动牙刷", "sentiment": "mixed"},
  {"text": "米家T501：充电座容易接触不良，要反复调整角度才能充上电。震动频率虚标，实际用起来跟几十块的杂牌差不多，还比不上我之前的飞利浦入门款。", "source": "淘宝用户评价", "product": "米家T501电动牙刷", "sentiment": "negative"},
  {"text": "usmile Y1：颜值高续航长，充一次电能用半年这个是真的。但刷头很硬，牙龈容易出血。送的那个旅行盒用几次就坏了。", "source": "小红书用户反馈", "product": "usmile Y1电动牙刷", "sentiment": "mixed"},

  // ============================================
  // 吹风机品类
  // ============================================
  {"text": "戴森HD15：3000多买个吹风机，风力确实大但没什么特别的。小米300块的吹风机风力也不差，差了10倍价格就是智商税。吹出来的风温度忽冷忽热，恒温就是个噱头。", "source": "京东用户评价", "product": "戴森HD15吹风机", "sentiment": "negative"},
  {"text": "追觅韶光：国产平替戴森，风力够大吹长发5分钟搞定。负离子确实有效果，吹完头发不毛躁。但用了半年风嘴配件卡扣松了，每次用都要手动按紧。", "source": "小红书用户反馈", "product": "追觅韶光吹风机", "sentiment": "mixed"},
  {"text": "徕芬SE-lite：200多块这个水平确实值。风温三档调节，吹刘海很方便。就是做工塑料感太强了，外壳感觉摔一下就报废。", "source": "天猫评价", "product": "徕芬SE-lite吹风机", "sentiment": "mixed"},

  // ============================================
  // 手机品类（二手市场防坑相关）
  // ============================================
  {"text": "闲鱼买了个iPhone 15说是国行在保，到手一查序列号发现是美版改的，电池还换过。卖家已经联系不上了，平台申诉也没用。翻新机水太深了大家一定当面验机。", "source": "小红书用户反馈", "product": "iPhone 15二手", "sentiment": "negative"},
  {"text": "转转买的iPhone 14 Pro：验机报告写着全原装，结果用了两周屏幕就出绿线了。去官方售后一查，屏幕根本不是原装，被换过国产屏。验机报告就是走形式，根本靠不住。", "source": "什么值得买社区", "product": "iPhone 14 Pro二手", "sentiment": "negative"},
  {"text": "闲鱼面交小米14 Ultra，卖家人挺好还让当面逐一检测。外观98新，仅用了3个月，比新的便宜了1500。查了发票和序列号都对得上，目前用了一个月一切正常。", "source": "京东用户评论引用", "product": "小米14 Ultra二手", "sentiment": "positive"},
  {"text": "拼多多买的号称官翻iPhone，收到发现充电口里面有灰，根本就是个人翻新贴了个官翻标签。IMEI查询激活时间也对不上。大家记住官翻只有官网和Apple Store可信。", "source": "淘宝用户评价", "product": "iPhone官翻机二手", "sentiment": "negative"},

  // ============================================
  // 耳机品类
  // ============================================
  {"text": "AirPods Pro 2：降噪确实牛，通勤坐地铁神器。但戴超过1小时耳朵就疼，入耳式通病没办法。最坑的是电池衰减太快，用了一年半，左耳从6小时掉到3小时。而且电池不能单独换。", "source": "京东用户评价", "product": "AirPods Pro 2", "sentiment": "negative"},
  {"text": "索尼WH-1000XM5：音质没得说，但夹头这个问题不是开玩笑的。戴一个小时太阳穴疼，对于头大的人慎重。而且不能折叠收纳，出门带很不方便。 3000多的东西连个折叠都不给。", "source": "小红书用户反馈", "product": "索尼WH-1000XM5", "sentiment": "negative"},
  {"text": "华强北AirPods：80块钱买到外观一模一样，基本看不出真假。但用一个月必坏，音质也一言难尽。便宜没好货，别浪费那80块。", "source": "淘宝用户评价", "product": "华强北AirPods", "sentiment": "negative"},

  // ============================================
  // 空调品类
  // ============================================
  {"text": "格力云佳KFR-35GW：空调本身还行，但安装师傅太坑了。铜管故意少带说要加长，多收了200块。支架说标配的不好推荐买升级版，又是150。一共多花了350安装费。", "source": "京东用户评价", "product": "格力云佳空调", "sentiment": "mixed"},
  {"text": "小米巨省电Pro：价格确实便宜，但压缩机噪音太大了。外机就装在卧室外墙，晚上嗡嗡响根本睡不着。找客服说正常范围内没法处理。", "source": "淘宝用户评价", "product": "小米巨省电Pro空调", "sentiment": "negative"},

  // ============================================
  // 投影仪品类
  // ============================================
  {"text": "极米Z7X：用了半年频繁自动关机，售后检测说是主板问题。维修费+运费500多，才买半年的机子。网上搜了一下发现这是Z系列通病，品控真的不行。", "source": "什么值得买社区", "product": "极米Z7X投影仪", "sentiment": "negative"},
  {"text": "小明Q3 Pro：1000块价位性价比最高。但是自动对焦不准，每次都要手动微调。梯形校正也是摆设，投墙有光斑很影响观感。", "source": "小红书用户反馈", "product": "小明Q3 Pro投影仪", "sentiment": "mixed"}
]
